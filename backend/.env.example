# ============================================
# TRIAGEIQ BACKEND — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================

# ---- AI API KEYS (get all 4 free) ----

# PRIMARY: Groq — console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_key_here

# FALLBACK 1: Google Gemini — aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza_your_gemini_key_here

# FALLBACK 2: OpenRouter — openrouter.ai → API Keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# FALLBACK 3: NVIDIA NIMs — build.nvidia.com → Developer Program
NVIDIA_API_KEY=nvapi-your_nvidia_key_here

# ---- App Config ----
APP_ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Database ----
DATABASE_URL=sqlite:///./triageiq.db
